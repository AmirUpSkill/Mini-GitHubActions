# ==============================================================================
# MISCELLANEOUS
# ==============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# Archive files (unless specifically needed)
*.zip
*.tar.gz
*.rar
*.7z

# Lock files (keep package-lock.json and pnpm-lock.yaml)
package-lock.json
!pnpm-lock.yaml

# Local configuration files
.localrc
.local

# Security and sensitive files
*.key
*.pem
*.p12
*.crt
*.csr
secrets.json
.secrets